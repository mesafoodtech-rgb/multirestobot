# Copiá a .env y completá. No commitear .env.

SUPABASE_URL=https://zqlkvgweofwvxdzmngxl.supabase.co
SUPABASE_KEY=clave_anon
SUPABASE_SERVICE_ROLE_KEY=clave_service_role

# Migraciones SQL (npm run db:migrate o POST /api/maestro/run-migrations):
# Supabase → Project Settings → Database → Connection string (URI)
SUPABASE_DB_URL=
# O solo la contraseña de postgres (el script arma la URL con SUPABASE_URL):
# SUPABASE_DB_PASSWORD=

OPENAI_API_KEY=
MP_ACCESS_TOKEN=
MESA_QR_SECRET=
MAESTRO_PASSWORD=
# 0 = solo API/carta/mesa (sin Chromium ni .wwebjs_auth en este proceso)
WHATSAPP_BOT_ENABLED=1
# Por restaurante con bot: WWEBJS_CLIENT_ID=slug-cliente y volumen .wwebjs_auth/slug-cliente
WWEBJS_CLIENT_ID=multirestobot-main
WWEBJS_AUTH_PATH=.wwebjs_auth

VITE_SUPABASE_URL=
VITE_SUPABASE_KEY=
VITE_MAESTRO_PASSWORD=
VITE_MESA_QR_SECRET=
# Puerto del bot en el host (docker-compose publica 3011)
VITE_BACKEND_PORT=3011

# Registro self-serve (mesafood.shop) y super-admin de plataforma
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=
PLATFORM_TEMPLATE_RESTAURANT_ID=
# Duración demo al registrarse (horas; default 24)
PUBLIC_DEMO_EXPIRES_HOURS=24
# URL base del panel clientes (login /d/{slug}/login)
PUBLIC_DASHBOARD_BASE_URL=https://app.mesafood.shop
# Orígenes CORS para la landing (coma-separados). Vacío = *
PLATFORM_CORS_ORIGINS=https://www.mesafood.shop,https://mesafood.shop
# Secreto para tokens Bearer del super-admin (si falta, usa MAESTRO_PASSWORD)
PLATFORM_SESSION_SECRET=
